<div class="max-w-md mx-auto mt-16 bg-white dark:bg-gray-800 p-8 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-50 dark:bg-red-900/30 mb-5 text-red-500 dark:text-red-400 font-medium rounded-lg inline-block w-full text-center" id="alert"><%= alert %></p>
  <% end %>

  <h1 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white">Two-Factor Authentication</h1>
  <p class="text-gray-600 dark:text-gray-300 mb-6">Open your authenticator app and enter the code to continue logging in.</p>

  <%= form_with url: two_factor_session_path, class: "space-y-4" do |form| %>
    <div>
      <%= form.label :otp_code, "Verification Code", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= form.text_field :otp_code, autocomplete: "one-time-code", inputmode: "numeric", pattern: "[0-9]*", class: "block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-center tracking-widest text-xl", placeholder: "123456", required: true, autofocus: true %>
    </div>

    <div>
      <%= form.submit "Verify", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-4 text-sm text-center">
    <%= link_to "Cancel login", new_session_path, class: "font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
  </div>
</div>