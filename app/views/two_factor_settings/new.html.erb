<div class="max-w-2xl mx-auto mt-8 bg-white dark:bg-gray-800 p-8 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 w-full">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Enable Two-Factor Authentication</h1>
    <p class="text-gray-500 dark:text-gray-400 mt-2">Scan the QR code below with your authenticator app to enable 2FA.</p>
  </div>

  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-50 dark:bg-red-900/30 mb-5 text-red-500 dark:text-red-400 font-medium rounded-lg inline-block w-full text-center" id="alert"><%= alert %></p>
  <% end %>

  <div class="flex flex-col items-center justify-center space-y-6 mb-8">
    <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-200">
      <%= raw @svg %>
    </div>
    
    <div class="text-center">
      <p class="text-sm font-medium text-gray-700 dark:text-gray-300">Or enter this code manually:</p>
      <code class="mt-2 inline-block px-3 py-1 bg-gray-100 dark:bg-gray-900 rounded text-lg tracking-widest font-mono text-gray-900 dark:text-white border border-gray-200 dark:border-gray-700"><%= @user.otp_secret %></code>
    </div>
  </div>

  <%= form_with url: two_factor_settings_path, method: :post, class: "space-y-6" do |form| %>
    <div>
      <%= form.label :otp_code, "Verification Code", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= form.text_field :otp_code, autocomplete: "one-time-code", inputmode: "numeric", pattern: "[0-9]*", class: "block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-center tracking-widest text-xl", placeholder: "123456", required: true, autofocus: true %>
    </div>

    <div class="pt-4 border-t border-gray-200 dark:border-gray-700 flex items-center justify-between">
      <%= link_to "Cancel", edit_profile_path, class: "text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors" %>
      <%= form.submit "Enable 2FA", class: "inline-flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>