<div class="max-w-md mx-auto mt-16 bg-white dark:bg-gray-800 p-8 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
  <h1 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white">Sign up</h1>

  <%= form_with(model: @user, url: registration_path, class: "space-y-4") do |form| %>
    <% if @user.errors.any? %>
      <div class="bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400 p-4 rounded-md">
        <h2 class="font-medium"><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h2>
        <ul class="list-disc ml-5 mt-2 text-sm">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :email_address, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= form.email_field :email_address, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white", required: true, autofocus: true %>
    </div>

    <div>
      <%= form.label :password, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= form.password_field :password, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white", required: true %>
    </div>

    <div>
      <%= form.label :password_confirmation, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= form.password_field :password_confirmation, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white", required: true %>
    </div>

    <div>
      <%= form.submit "Sign up", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    </div>
  <% end %>

  <div class="mt-4 text-sm text-center">
    <%= link_to "Already have an account? Sign in", new_session_path, class: "font-medium text-blue-600 dark:text-blue-400 hover:text-blue-500" %>
  </div>
</div>