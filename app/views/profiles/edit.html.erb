<div class="max-w-2xl mx-auto mt-8 bg-white dark:bg-gray-800 p-8 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 w-full">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Edit Profile</h1>
    <p class="text-gray-500 dark:text-gray-400 mt-2">Manage your personal information and profile settings.</p>
  </div>

  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-green-50 dark:bg-green-900/30 mb-5 text-green-500 dark:text-green-400 font-medium rounded-lg inline-block w-full text-center" id="notice"><%= notice %></p>
  <% end %>

  <%= form_with(model: @user, url: profile_path, method: :patch, class: "space-y-6") do |form| %>
    <% if @user.errors.any? %>
      <div class="bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400 p-4 rounded-md">
        <h2 class="font-medium"><%= pluralize(@user.errors.count, "error") %> prohibited this profile from being saved:</h2>
        <ul class="list-disc ml-5 mt-2 text-sm">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="flex items-center space-x-6">
      <div class="flex-shrink-0">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, class: "h-16 w-16 object-cover rounded-full shadow-sm ring-2 ring-gray-200 dark:ring-gray-700" %>
        <% else %>
          <span class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-blue-100 dark:bg-blue-900 shadow-sm ring-2 ring-gray-200 dark:ring-gray-700">
            <span class="text-xl font-medium leading-none text-blue-700 dark:text-blue-300"><%= @user.initials %></span>
          </span>
        <% end %>
      </div>
      <div>
        <%= form.label :avatar, "Profile Photo", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= form.file_field :avatar, class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 dark:file:bg-blue-900/50 dark:file:text-blue-300" %>
      </div>
    </div>

    <div class="flex space-x-4">
      <div class="w-1/2">
        <%= form.label :first_name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= form.text_field :first_name, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white" %>
      </div>
      <div class="w-1/2">
        <%= form.label :last_name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= form.text_field :last_name, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white" %>
      </div>
    </div>

    <div>
      <%= form.label :location, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= form.text_field :location, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white", placeholder: "e.g. New York, USA" %>
    </div>

    <div>
      <%= form.label :bio, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= form.text_area :bio, rows: 4, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white", placeholder: "Tell us a bit about yourself..." %>
    </div>

    <div class="pt-4 border-t border-gray-200 dark:border-gray-700 flex items-center justify-between">
      <%= link_to "Cancel", root_path, class: "text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors" %>
      <%= form.submit "Update Profile", class: "inline-flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Two-Factor Authentication</h2>
    <% if @user.otp_enabled? %>
      <div class="bg-green-50 dark:bg-green-900/30 p-4 rounded-md mb-4 border border-green-200 dark:border-green-800">
        <div class="flex items-center">
          <svg class="h-5 w-5 text-green-400 dark:text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span class="text-sm font-medium text-green-800 dark:text-green-200">Two-factor authentication is currently enabled.</span>
        </div>
      </div>
      <%= form_with url: two_factor_settings_path, method: :delete, class: "space-y-4" do |form| %>
        <div>
          <%= form.label :password, "Confirm password to disable 2FA", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= form.password_field :password, class: "block w-full md:w-1/2 rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-red-500 focus:ring-red-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white", required: true %>
        </div>
        <%= form.submit "Disable 2FA", class: "inline-flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors cursor-pointer", data: { turbo_confirm: "Are you sure you want to disable 2FA?" } %>
      <% end %>
    <% else %>
      <div class="bg-gray-50 dark:bg-gray-800/50 p-4 rounded-md mb-4 border border-gray-200 dark:border-gray-700">
        <span class="text-sm text-gray-600 dark:text-gray-400">Two-factor authentication adds an extra layer of security to your account.</span>
      </div>
      <%= link_to "Enable 2FA", new_two_factor_settings_path, class: "inline-flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-gray-600 hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 transition-colors cursor-pointer" %>
    <% end %>
  </div>
</div>
