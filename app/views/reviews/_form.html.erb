<%= form_with(model: [tool, review], class: "bg-gray-50 dark:bg-gray-900 p-4 rounded-lg border border-gray-200 dark:border-gray-700") do |f| %>
  <h5 class="text-lg font-medium text-gray-900 dark:text-white mb-3">Leave a Review</h5>
  
  <div class="mb-4" data-controller="rating">
    <%= f.label :rating, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.hidden_field :rating, data: { rating_target: "input" } %>
    <div class="flex items-center space-x-1" data-action="mouseleave->rating#leave">
      <% (1..5).each do |i| %>
        <button type="button" 
                class="focus:outline-none transition-transform hover:scale-110" 
                data-action="mouseenter->rating#hover click->rating#select" 
                data-rating-target="star" 
                data-value="<%= i %>">
          <svg class="w-8 h-8 text-gray-300 dark:text-gray-600 transition-colors" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        </button>
      <% end %>
    </div>
  </div>

  <div class="mb-4">
    <%= f.label :content, "Review", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_area :content, rows: 3, class: "shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md dark:bg-gray-800 dark:border-gray-700 dark:text-white", placeholder: "What do you think about this tool?", required: true %>
  </div>

  <div class="flex justify-end">
    <%= f.submit "Post Review", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors cursor-pointer" %>
  </div>
<% end %>