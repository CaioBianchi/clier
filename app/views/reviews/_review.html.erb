<div id="<%= dom_id(review) %>" class="bg-white dark:bg-gray-800 p-4 rounded-lg border border-gray-200 dark:border-gray-700 shadow-sm">
  <div class="flex items-center justify-between mb-2">
    <div class="flex items-center space-x-2">
      <% if review.user.avatar.attached? %>
        <%= image_tag review.user.avatar, class: "h-6 w-6 object-cover rounded-full shadow-sm ring-1 ring-gray-200 dark:ring-gray-700" %>
      <% else %>
        <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-blue-100 dark:bg-blue-900 shadow-sm ring-1 ring-gray-200 dark:ring-gray-700">
          <span class="text-[10px] font-medium leading-none text-blue-700 dark:text-blue-300"><%= review.user.initials %></span>
        </span>
      <% end %>
      <span class="font-medium text-gray-900 dark:text-white"><%= "#{review.user.first_name} #{review.user.last_name}" %></span>
      <span class="text-sm text-gray-500 dark:text-gray-400">&bull;</span>
      <span class="text-sm text-gray-500 dark:text-gray-400" title="<%= review.created_at.to_fs(:long) %>"><%= time_ago_in_words(review.created_at) %> ago</span>
    </div>
    <div class="flex items-center">
      <% 5.times do |i| %>
        <svg class="w-4 h-4 <%= i < review.rating ? 'text-yellow-400' : 'text-gray-300 dark:text-gray-600' %>" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      <% end %>
    </div>
  </div>
  <p class="text-gray-700 dark:text-gray-300 whitespace-pre-wrap"><%= review.content %></p>
  <% if review.user == Current.user %>
    <div class="mt-3 flex justify-end">
      <%= button_to "Delete", tool_review_path(review.tool, review), method: :delete, class: "text-sm text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-300 focus:outline-none", data: { turbo_confirm: "Are you sure?" } %>
    </div>
  <% end %>
</div>