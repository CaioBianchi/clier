<div class="w-full">
  <% if @spotlight_tool && params[:page].blank? && params[:query].blank? && params[:category].blank? && params[:favorites].blank? %>
    <div class="mb-12 rounded-2xl overflow-hidden relative shadow-lg group">
      <div class="absolute inset-0 bg-gradient-to-r from-blue-600 to-indigo-700 dark:from-blue-800 dark:to-indigo-900 opacity-90"></div>
      <div class="relative p-8 sm:p-12 flex flex-col sm:flex-row items-center justify-between text-white gap-6">
        <div class="flex-1">
          <div class="inline-flex items-center space-x-2 bg-white/20 rounded-full px-3 py-1 mb-4 text-sm font-medium backdrop-blur-sm">
            <span>🌟 Tool of the Week</span>
          </div>
          <h2 class="text-3xl sm:text-4xl font-bold mb-3"><%= @spotlight_tool.name %></h2>
          <p class="text-blue-100 text-lg sm:text-xl max-w-2xl mb-6"><%= @spotlight_tool.description %></p>
          <div class="flex items-center space-x-4">
            <%= link_to tool_path(@spotlight_tool), class: "inline-flex items-center px-5 py-3 border border-transparent text-base font-medium rounded-md text-blue-700 bg-white hover:bg-blue-50 transition-colors shadow-sm", data: { turbo_frame: "modal" } do %>
              View Details
              <svg class="ml-2 -mr-1 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            <% end %>
            <% if @spotlight_tool.github_stars %>
              <div class="flex items-center text-blue-100">
                <svg class="w-5 h-5 mr-1.5 text-yellow-300" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                <span class="font-medium"><%= number_to_human(@spotlight_tool.github_stars, format: "%n%u", units: { thousand: "k", million: "M" }) %> stars</span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
    <div>
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white transition-colors">Popular CLI Tools</h1>
      <p class="text-gray-500 dark:text-gray-400 mt-2 transition-colors">Discover and download the best terminal apps</p>
    </div>
    
    <div class="w-full sm:w-auto flex flex-col sm:flex-row items-center gap-3">
      <% if params[:favorites].present? %>
        <%= link_to tools_path(query: params[:query], category: params[:category]), class: "inline-flex items-center px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md text-sm bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors group h-[38px] whitespace-nowrap", data: { turbo_action: "advance" } do %>
          <span class="mr-1">Filtered by:</span>
          <span class="font-semibold text-blue-600 dark:text-blue-400 mr-2">Favorites</span>
          <svg class="w-4 h-4 text-gray-400 group-hover:text-red-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        <% end %>
      <% end %>

      <% if params[:category].present? %>
        <%= link_to tools_path(query: params[:query], favorites: params[:favorites]), class: "inline-flex items-center px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md text-sm bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors group h-[38px] whitespace-nowrap", data: { turbo_action: "advance" } do %>
          <span class="mr-1">Category:</span>
          <span class="font-semibold text-blue-600 dark:text-blue-400 mr-2"><%= params[:category] %></span>
          <svg class="w-4 h-4 text-gray-400 group-hover:text-red-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        <% end %>
      <% end %>
      
      <%= form_with url: tools_path, method: :get, class: "relative w-full sm:w-72", data: { turbo_frame: "tools_list", turbo_action: "advance" } do |f| %>
        <% if params[:category].present? %>
          <%= f.hidden_field :category, value: params[:category] %>
        <% end %>
        <% if params[:favorites].present? %>
          <%= f.hidden_field :favorites, value: params[:favorites] %>
        <% end %>
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
          </svg>
        </div>
        <%= f.text_field :query, value: params[:query], placeholder: "Search tools...", class: "block w-full pl-10 pr-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md leading-5 bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-500 focus:outline-none focus:placeholder-gray-400 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-colors", oninput: "this.form.requestSubmit()" %>
      <% end %>
    </div>
  </div>

  <div class="mb-8">
    <div class="flex flex-wrap gap-2">
      <%= link_to "All", tools_path(query: params[:query], favorites: params[:favorites]), 
          class: "px-4 py-2 rounded-full text-sm font-medium transition-colors #{params[:category].blank? ? 'bg-blue-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700'}",
          data: { turbo_action: "advance" } %>
      
      <% @categories.each do |category| %>
        <%= link_to category, tools_path(category: category, query: params[:query], favorites: params[:favorites]), 
            class: "px-4 py-2 rounded-full text-sm font-medium transition-colors #{params[:category] == category ? 'bg-blue-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700'}",
            data: { turbo_action: "advance" } %>
      <% end %>
    </div>
  </div>

  <%= turbo_frame_tag "tools_list" do %>
    <div id="tools_grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <%= render partial: "tool", collection: @tools %>
    </div>

    <% unless @tools.last_page? %>
      <%= turbo_frame_tag "tools_pagination", src: tools_path(page: @tools.next_page, query: params[:query], category: params[:category], favorites: params[:favorites], format: :turbo_stream), loading: :lazy do %>
        <div class="flex justify-center py-8 w-full">
          <svg class="animate-spin h-8 w-8 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>