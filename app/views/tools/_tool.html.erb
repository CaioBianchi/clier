<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden hover:shadow-md transition-all flex flex-col h-full relative group">
  <div class="p-6 flex-grow flex flex-col">
    <div class="flex items-start justify-between mb-4 gap-2">
      <div class="min-w-0 flex-grow">
        <%= link_to tool_path(tool), data: { turbo_frame: "modal", turbo_action: "advance" }, class: "hover:underline focus:outline-none focus:ring-2 focus:ring-blue-500 rounded block" do %>
          <h2 class="text-2xl font-semibold text-gray-900 dark:text-white transition-colors truncate" title="<%= tool.name %>"><%= tool.name %></h2>
        <% end %>
      </div>
      
      <div class="flex items-center gap-2 shrink-0">
        <% if tool.github_stars %>
          <span class="inline-flex items-center text-sm font-medium text-gray-500 dark:text-gray-400" title="<%= tool.github_stars %> stars">
            <svg class="w-4 h-4 mr-1 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
            <%= number_to_human(tool.github_stars, format: "%n%u", units: { thousand: "k", million: "M" }) %>
          </span>
        <% end %>
        
        <%= link_to tools_path(category: tool.category), class: "inline-flex items-center rounded-full bg-blue-50 dark:bg-blue-900/30 px-2.5 py-0.5 text-xs font-medium text-blue-700 dark:text-blue-300 ring-1 ring-inset ring-blue-700/10 dark:ring-blue-400/20 hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors whitespace-nowrap", data: { turbo_frame: "_top" } do %>
          <%= tool.category %>
        <% end %>

        <% if authenticated? %>
          <%= turbo_frame_tag "favorite_tool_#{tool.id}" do %>
            <% if Current.user.favorites.exists?(tool: tool) %>
              <%= button_to tool_favorite_path(tool), method: :delete, class: "p-1.5 bg-gray-100 dark:bg-gray-700 rounded-full shadow-sm hover:scale-110 transition-transform text-red-500" do %>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path></svg>
              <% end %>
            <% else %>
              <%= button_to tool_favorite_path(tool), method: :post, class: "p-1.5 bg-gray-100 dark:bg-gray-700 rounded-full shadow-sm hover:scale-110 transition-transform text-gray-400 hover:text-red-500" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

    <% if tool.image_url.present? %>
      <div class="mb-4 h-48 flex items-center justify-center bg-gray-50 dark:bg-gray-900 rounded-lg overflow-hidden border border-gray-100 dark:border-gray-700">
        <img src="<%= tool.image_url %>" alt="<%= tool.name %> logo" class="w-full h-full object-cover">
      </div>
    <% else %>
      <div class="mb-4 h-48 flex items-center justify-center bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-100 dark:border-gray-700">
        <span class="text-4xl">💻</span>
      </div>
    <% end %>

    <p class="text-gray-600 dark:text-gray-300 text-sm mb-6 flex-grow transition-colors"><%= tool.description %></p>

    <div class="space-y-2 mt-auto">
      <% if tool.stable_version.present? %>
        <div class="flex justify-between items-center text-sm bg-gray-50 dark:bg-gray-900/50 px-3 py-2 rounded-md transition-colors">
          <span class="text-gray-600 dark:text-gray-400 font-medium">Stable</span>
          <span class="font-semibold text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/30 px-2 py-0.5 rounded-md"><%= tool.stable_version %></span>
        </div>
      <% end %>
      <% if tool.beta_version.present? %>
        <div class="flex justify-between items-center text-sm bg-gray-50 dark:bg-gray-900/50 px-3 py-2 rounded-md transition-colors">
          <span class="text-gray-600 dark:text-gray-400 font-medium">Beta</span>
          <span class="font-semibold text-amber-600 dark:text-amber-400 bg-amber-50 dark:bg-amber-900/30 px-2 py-0.5 rounded-md"><%= tool.beta_version %></span>
        </div>
      <% end %>
    </div>
  </div>

  <div class="bg-gray-50 dark:bg-gray-800/50 px-6 py-4 flex gap-3 border-t border-gray-200 dark:border-gray-700 transition-colors">
    <% if tool.website_url.present? %>
      <a href="<%= tool.website_url %>" target="_blank" rel="noopener noreferrer" class="flex-1 inline-flex justify-center items-center rounded-md bg-white dark:bg-gray-700 px-3 py-2 text-sm font-semibold text-gray-900 dark:text-white shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">
        <svg class="w-4 h-4 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
        Website
      </a>
    <% end %>
    <% if tool.github_url.present? %>
      <a href="<%= tool.github_url %>" target="_blank" rel="noopener noreferrer" class="flex-1 inline-flex justify-center items-center rounded-md bg-gray-900 dark:bg-gray-100 px-3 py-2 text-sm font-semibold text-white dark:text-gray-900 shadow-sm hover:bg-gray-800 dark:hover:bg-white transition-colors">
        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
        GitHub
      </a>
    <% end %>
  </div>
</div>
