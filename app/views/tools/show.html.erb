<%= turbo_frame_tag "modal" do %>
  <div class="relative z-50" aria-labelledby="modal-title" role="dialog" aria-modal="true" data-controller="modal" data-action="keyup@window->modal#escClose">
    <div class="fixed inset-0 bg-gray-500/75 dark:bg-gray-900/80 transition-opacity" data-action="click->modal#close"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto">
      <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0" data-action="click->modal#backdropClick">
        <div class="relative transform overflow-hidden rounded-lg bg-white dark:bg-gray-800 text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-4xl border border-gray-200 dark:border-gray-700">
          <div class="absolute right-0 top-0 hidden pr-4 pt-4 sm:block z-10">
            <%= link_to tools_path, class: "rounded-md bg-white dark:bg-gray-800 text-gray-400 hover:text-gray-500 dark:hover:text-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors", data: { turbo_frame: "_top", turbo_action: "advance", action: "click->modal#close" } do %>
              <span class="sr-only">Close</span>
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            <% end %>
          </div>

          <div class="bg-white dark:bg-gray-800 px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
            <% if alert = flash[:alert] %>
              <p class="py-2 px-3 bg-red-50 dark:bg-red-900/30 mb-5 text-red-500 dark:text-red-400 font-medium rounded-lg inline-block w-full text-center" id="alert"><%= alert %></p>
            <% end %>
            <% if notice = flash[:notice] %>
              <p class="py-2 px-3 bg-green-50 dark:bg-green-900/30 mb-5 text-green-500 dark:text-green-400 font-medium rounded-lg inline-block w-full text-center" id="notice"><%= notice %></p>
            <% end %>

            <div class="sm:flex sm:items-start mb-6">
              <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left w-full">
                <div class="flex items-center justify-between">
                  <h3 class="text-3xl font-semibold leading-6 text-gray-900 dark:text-white transition-colors" id="modal-title">
                    <%= @tool.name %>
                  </h3>
                  <div class="flex items-center gap-3 sm:mr-8">
                    <% if @tool.github_stars %>
                      <span class="inline-flex items-center text-sm font-medium text-gray-500 dark:text-gray-400">
                        <svg class="w-5 h-5 mr-1 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                        <%= number_to_human(@tool.github_stars, format: "%n%u", units: { thousand: "k", million: "M" }) %>
                      </span>
                    <% end %>
                    <span class="inline-flex items-center rounded-full bg-blue-50 dark:bg-blue-900/30 px-3 py-1 text-sm font-medium text-blue-700 dark:text-blue-300 ring-1 ring-inset ring-blue-700/10 dark:ring-blue-400/20"><%= @tool.category %></span>
                  </div>
                </div>
                <div class="mt-2">
                  <p class="text-lg text-gray-600 dark:text-gray-300 transition-colors"><%= @tool.description %></p>
                </div>
              </div>
            </div>

            <div class="mt-4 border-t border-gray-200 dark:border-gray-700 pt-6">
              <% if @readme_html.present? %>
                <h4 class="text-xl font-bold mb-4 text-gray-900 dark:text-white">README</h4>
                <div class="bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700 p-6 relative" data-controller="read-more">
                  <div data-read-more-target="content" class="prose prose-slate prose-sm sm:prose-base dark:prose-invert max-w-none overflow-x-auto selection:bg-blue-100 dark:selection:bg-blue-900 pb-8">
                    <%= sanitize @readme_html, tags: %w(h1 h2 h3 h4 h5 h6 p b i em strong a pre code blockquote ul ol li img div span hr table thead tbody tr th td details summary del kbd ins sup sub), attributes: %w(href src alt class id style title width height align target name) %>
                  </div>
                  
                  <div data-read-more-target="overlay" class="hidden absolute bottom-0 left-0 w-full h-48 bg-gradient-to-t from-gray-50 dark:from-gray-900 to-transparent pointer-events-none rounded-b-lg"></div>
                  <div data-read-more-target="buttonContainer" class="hidden absolute bottom-6 left-0 w-full justify-center">
                    <button type="button" data-action="click->read-more#expand" class="bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 shadow-sm rounded-full px-6 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none transition-colors flex items-center">
                      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                      Read full README
                    </button>
                  </div>
                </div>
              <% else %>
                <div class="bg-gray-50 dark:bg-gray-900 p-8 rounded-lg border border-gray-200 dark:border-gray-700 text-center shadow-sm">
                  <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                  </svg>
                  <h4 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No README available</h4>
                  <p class="text-gray-500 dark:text-gray-400 mb-6">We couldn't fetch the README for this tool. You can still install or learn more by visiting its repository.</p>
                  
                  <% if @tool.github_url.present? %>
                    <div class="inline-block text-left bg-white dark:bg-gray-800 rounded-md border border-gray-200 dark:border-gray-700 p-4 w-full max-w-md">
                      <h5 class="text-sm font-medium text-gray-900 dark:text-white mb-3">Quick Install (if applicable):</h5>
                      <div class="flex items-center space-x-2 bg-gray-100 dark:bg-gray-900 p-3 rounded text-sm text-gray-800 dark:text-gray-300 font-mono overflow-x-auto border border-gray-200 dark:border-gray-700 shadow-inner">
                        <span class="text-gray-400 select-none">$</span>
                        <code class="text-pink-600 dark:text-pink-400 font-bold whitespace-nowrap">gh repo clone <%= @tool.github_url.split("github.com/").last %></code>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>

            <div class="mt-8 border-t border-gray-200 dark:border-gray-700 pt-6">
              <h4 class="text-xl font-bold mb-4 text-gray-900 dark:text-white">Reviews</h4>
              
              <div id="reviews" class="space-y-4 mb-6">
                <%= render @tool.reviews.includes(:user).order(created_at: :desc) %>
                <% if @tool.reviews.empty? %>
                  <p class="text-gray-500 dark:text-gray-400 italic text-sm">No reviews yet. Be the first to review this tool!</p>
                <% end %>
              </div>

              <% if authenticated? %>
                <%= render "reviews/form", tool: @tool, review: Review.new %>
              <% else %>
                <div class="bg-gray-50 dark:bg-gray-900 p-4 rounded-lg border border-gray-200 dark:border-gray-700 text-center">
                  <p class="text-gray-600 dark:text-gray-300">Please <%= link_to "log in", new_session_path, class: "text-blue-600 dark:text-blue-400 hover:underline", data: { turbo_frame: "_top" } %> to leave a review.</p>
                </div>
              <% end %>
            </div>
          </div>

          <div class="bg-gray-50 dark:bg-gray-800/50 px-4 py-4 sm:px-6 border-t border-gray-200 dark:border-gray-700 transition-colors">
            <div class="flex flex-col gap-4">
              <!-- Top row: Primary action & Close -->
              <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-2 sm:ml-auto">
                  <%= link_to "Close", tools_path, class: "inline-flex items-center rounded-md bg-white dark:bg-gray-700 px-4 py-2 text-sm font-semibold text-gray-900 dark:text-white shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors", data: { turbo_frame: "_top", turbo_action: "advance", action: "click->modal#close" } %>
                </div>
              </div>

              <!-- Bottom row: Meta links & Admin -->
              <div class="flex flex-col sm:flex-row items-center justify-between border-t border-gray-200 dark:border-gray-700 pt-4 gap-4">
                <div class="flex flex-wrap items-center justify-center sm:justify-start gap-3">
                  <% if @tool.github_url.present? %>
                    <a href="<%= @tool.github_url %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
                      <svg class="w-5 h-5 mr-1.5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
                      GitHub
                    </a>
                  <% end %>
                  <% if @tool.website_url.present? %>
                    <a href="<%= @tool.website_url %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
                      <svg class="w-5 h-5 mr-1.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
                      Website
                    </a>
                  <% end %>
                </div>

                <% if authenticated? && Current.user.admin? %>
                  <div class="flex items-center gap-2">
                    <%= button_to "Spotlight", spotlight_tool_path(@tool), method: :patch, class: "text-xs font-semibold text-yellow-600 hover:text-yellow-500 transition-colors", data: { turbo_frame: "_top" } %>
                    <span class="text-gray-300 dark:text-gray-600">|</span>
                    <%= button_to "Delete", tool_path(@tool), method: :delete, class: "text-xs font-semibold text-red-600 hover:text-red-500 transition-colors", data: { turbo_frame: "_top", turbo_confirm: "Are you sure?" } %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
